@model NewsAggregator.Models.Post
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    var relatedPosts = ViewBag.RelatedPosts as List<NewsAggregator.Models.Post>
                       ?? new List<NewsAggregator.Models.Post>();
    bool isSaved = ViewBag.IsSaved == true;
}

<section class="single-block-wrapper section-padding">
    <div class="container">
        <div class="row">

            @* ===== CỘT CHÍNH — NỘI DUNG BÀI VIẾT ===== *@
            <div class="col-lg-8 col-md-12 col-sm-12 col-xs-12">

                @* PHẦN HEADER BÀI VIẾT *@
                <div class="single-post">
                    <div class="post-header mb-5">

                        @* Danh mục bài viết *@
                        <a class="post-category"
                           asp-controller="News"
                           asp-action="Category"
                           asp-route-id="@Model.MenuID">
                            @Model.Menu?.MenuName
                        </a>

                        @* Tiêu đề + logo nguồn báo *@
                        <h2 class="post-title">@Model.Title</h2>
                        @if (Model.Source != null && !string.IsNullOrEmpty(Model.Source.LogoUrl))
                        {
                            <div class="source-logo mb-2">
                                <a href="@Model.Source.WebsiteUrl" target="_blank" rel="noopener"
                                   title="@Model.Source.SourceName">
                                    <img src="@Model.Source.LogoUrl"
                                         alt="@Model.Source.SourceName"
                                         style="max-height:28px; max-width:120px; object-fit:contain; vertical-align:middle;" />
                                </a>
                            </div>
                        }

                        @* Thông tin meta *@
                        <div class="post-meta mb-3">
                            @* Nút lưu bài viết *@
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <div class="mb-2">
                                    <button id="btn-save-post"
                                            class="btn btn-sm @(isSaved ? "btn-warning" : "btn-outline-warning")"
                                            onclick="toggleSave(@Model.PostID)">
                                        <i class="fa @(isSaved ? "fa-bookmark" : "fa-bookmark-o") mr-1"></i>
                                        @(isSaved ? "Đã lưu" : "Lưu bài viết")
                                    </button>
                                    <span id="save-msg" class="ml-2 text-muted small"></span>
                                </div>
                            }

                            @* Nút TTS *@
                            <div class="tts-controls mt-3 mb-3">
                                <button id="btn-play" onclick="startReading()" class="btn btn-primary btn-sm">
                                    <i class="fa fa-volume-up mr-1"></i> Đọc bài viết
                                </button>
                                <button id="btn-pause" onclick="pauseReading()"
                                        class="btn btn-warning btn-sm" style="display:none">
                                    <i class="fa fa-pause mr-1"></i> Tạm dừng
                                </button>
                                <button id="btn-stop" onclick="stopReading()"
                                        class="btn btn-secondary btn-sm" style="display:none">
                                    <i class="fa fa-stop mr-1"></i> Dừng
                                </button>
                                <span id="tts-status" class="text-muted ml-2" style="font-size:13px"></span>
                            </div>

                            <span class="posted-time">
                                <i class="fa fa-clock-o mr-2"></i>
                                @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                            </span>
                            <span class="post-author ml-3">
                                by <strong>@Model.Author</strong>
                            </span>
                            <span class="ml-3">
                                <i class="fa fa-eye mr-1"></i>
                                @Model.ViewCount lượt xem
                            </span>
                            @if (Model.Source != null)
                            {
                                <span class="ml-3">
                                    <i class="fa fa-newspaper-o mr-1"></i>
                                    Nguồn:
                                    <a href="@Model.Source.WebsiteUrl"
                                       target="_blank">
                                        @Model.Source.SourceName
                                    </a>
                                </span>
                            }
                        </div>

                        @* Tóm tắt bài viết *@
                        <p>@Model.Abstract</p>
                    </div>

                    @* PHẦN THÂN BÀI VIẾT *@
                    <div class="post-body">

                        @* Nội dung bài viết *@
                        <div class="entry-content">
                            @if (!string.IsNullOrEmpty(Model.Contents))
                            {
                                @* Bài có nội dung đầy đủ: ảnh nằm đúng vị trí trong content *@
                                @Html.Raw(Model.Contents)
                            }
                            else
                            {
                                @* Bài chỉ có RSS summary: hiện thumbnail + tóm tắt + link gốc *@
                                @if (!string.IsNullOrEmpty(Model.Images))
                                {
                                    <div class="post-featured-image mb-4">
                                        <img src="@Model.Images" class="img-fluid" alt="@Model.Title">
                                    </div>
                                }
                                <p>@Model.Abstract</p>
                                <p>
                                    <a href="@Model.Link" target="_blank" class="btn btn-primary">
                                        Đọc bài đầy đủ tại @Model.Source?.SourceName
                                        <i class="fa fa-external-link ml-2"></i>
                                    </a>
                                </p>
                            }
                        </div>

                        @* SHARE + TAGS *@
                        <div class="share-block d-flex justify-content-between
                                    align-items-center border-top border-bottom mt-5">
                            <div class="post-tags">
                                <span>Danh mục: </span>
                                <a asp-controller="News"
                                   asp-action="Category"
                                   asp-route-id="@Model.MenuID">
                                    @Model.Menu?.MenuName
                                </a>
                            </div>
                            <ul class="share-icons list-unstyled">
                                <li class="facebook">
                                    <a href="https://www.facebook.com/sharer/sharer.php?u=@Model.Link"
                                       target="_blank">
                                        <i class="fa fa-facebook"></i>
                                    </a>
                                </li>
                                <li class="twitter">
                                    <a href="https://twitter.com/intent/tweet?url=@Model.Link&text=@Model.Title"
                                       target="_blank">
                                        <i class="fa fa-twitter"></i>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                @* ===== BÀI VIẾT LIÊN QUAN ===== *@
                @if (relatedPosts.Any())
                {
                    <div class="related-posts-block mt-5">
                        <h3 class="news-title">
                            <span>Bài viết liên quan</span>
                        </h3>
                        <div class="news-style-two-slide">
                            @foreach (var p in relatedPosts)
                            {
                                <div class="item">
                                    <div class="post-block-wrapper clearfix">
                                        <div class="post-thumbnail mb-0">
                                            <a asp-controller="News"
                                               asp-action="Detail"
                                               asp-route-id="@p.PostID">
                                                <img class="img-fluid"
                                                     src="@(string.IsNullOrEmpty(p.Images)
                                                        ? "/images/news/news-04.jpg"
                                                        : p.Images)"
                                                     alt="@p.Title" />
                                            </a>
                                        </div>
                                        <a class="post-category"
                                           asp-controller="News"
                                           asp-action="Category"
                                           asp-route-id="@p.MenuID">
                                            @p.Menu?.MenuName
                                        </a>
                                        <div class="post-content">
                                            <h2 class="post-title title-sm">
                                                <a asp-controller="News"
                                                   asp-action="Detail"
                                                   asp-route-id="@p.PostID">
                                                    @p.Title
                                                </a>
                                            </h2>
                                            <div class="post-meta">
                                                <span class="posted-time">
                                                    <i class="fa fa-clock-o mr-1"></i>
                                                    @p.CreatedDate.ToString("dd/MM/yyyy")
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>

            @* ===== SIDEBAR PHẢI ===== *@
            <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                <div class="sidebar sidebar-right">

                    @* Thông tin nguồn báo *@
                    @if (Model.Source != null)
                    {
                        <div class="widget">
                            <h3 class="news-title"><span>Nguồn báo</span></h3>
                            <div class="text-center p-3">
                                <p>
                                    <i class="fa fa-newspaper-o mr-2"></i>
                                    <strong>@Model.Source.SourceName</strong>
                                </p>
                                <a href="@Model.Link"
                                   target="_blank"
                                   class="btn btn-primary btn-sm">
                                    <i class="fa fa-external-link mr-1"></i>
                                    Xem bài gốc
                                </a>
                            </div>
                        </div>
                    }

                    @* Bài viết liên quan dạng list trong sidebar *@
                    @if (relatedPosts.Any())
                    {
                        <div class="widget">
                            <h3 class="news-title"><span>Có thể bạn thích</span></h3>
                            <div class="post-list-block">
                                @foreach (var p in relatedPosts)
                                {
                                    <div class="post-block-wrapper post-float clearfix">
                                        <div class="post-thumbnail">
                                            <a asp-controller="News"
                                               asp-action="Detail"
                                               asp-route-id="@p.PostID">
                                                <img class="img-fluid"
                                                     src="@(string.IsNullOrEmpty(p.Images)
                                                        ? "/images/news/news-03.jpg"
                                                        : p.Images)"
                                                     alt="@p.Title" />
                                            </a>
                                        </div>
                                        <div class="post-content">
                                            <h2 class="post-title title-sm">
                                                <a asp-controller="News"
                                                   asp-action="Detail"
                                                   asp-route-id="@p.PostID">
                                                    @p.Title
                                                </a>
                                            </h2>
                                            <div class="post-meta">
                                                <span class="posted-time">
                                                    <i class="fa fa-clock-o mr-1"></i>
                                                    @p.CreatedDate.ToString("dd/MM/yyyy")
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</section>
@section Styles {
<style>
    /* ===== Fix ảnh trong nội dung bài viết ===== */

    /* Ảnh không bị tràn, giữ tỉ lệ */
    .entry-content img {
        max-width: 100% !important;
        width: auto !important;
        height: auto !important;
        display: block;
        margin: 12px auto;
        border-radius: 4px;
    }
    /* Ảnh broken → ẩn đi */
    .entry-content img.img-broken { display: none !important; }

    /* Figure/picture: xóa khoảng trắng do fixed size */
    .entry-content figure,
    .entry-content picture {
        max-width: 100% !important;
        height: auto !important;
        min-height: 0 !important;
        margin: 16px auto;
        display: block;
        text-align: center;
    }
    .entry-content figure * {
        height: auto !important;
        max-width: 100% !important;
    }
    .entry-content figcaption {
        font-size: 13px;
        color: #666;
        margin-top: 6px;
        font-style: italic;
        text-align: center;
    }
    /* Xóa khoảng trắng của các wrapper ảnh phổ biến */
    .entry-content .VCSortableInPreviewMode,
    .entry-content .box_content_detail,
    .entry-content .fig-picture,
    .entry-content [data-type="Photo"],
    .entry-content .article-body-image-wrapper,
    .entry-content .item_slide_show,
    .entry-content .imagefull,
    .entry-content .image_article {
        height: auto !important;
        min-height: 0 !important;
        padding-top: 0 !important;
    }

    /* Ảnh đại diện đầu bài */
    .post-featured-image img {
        max-width: 100%;
        height: auto;
        border-radius: 6px;
    }
    .source-logo img { opacity: 0.85; }
    .source-logo img:hover { opacity: 1; }
</style>
}
@section Scripts {
<script>
    // --- State ---
    let audioQueue   = [];   // danh sách URL audio đã tạo
    let currentAudio = null; // Audio object đang phát (để pause/stop thực sự)
    let isPaused     = false;
    let isStopped    = false;
    let currentIndex = 0;

    // --- Lấy nội dung bài viết dưới dạng plain-text gửi lên server làm sạch ---
    function getRawContent() {
        const title    = document.querySelector('.post-title')?.innerText ?? '';
        const abstract = document.querySelector('.post-header > p')?.innerText ?? '';
        const body     = document.querySelector('.entry-content')?.innerHTML ?? '';
        return `${title}. ${abstract}. ${body}`;
    }

    // --- Nút Đọc bài viết ---
    async function startReading() {
        if (isPaused) { resumeReading(); return; }

        isStopped    = false;
        isPaused     = false;
        currentIndex = 0;
        audioQueue   = [];

        const rawContent = getRawContent();
        if (!rawContent.trim()) { setStatus('Không có nội dung!'); return; }

        // Chia thành các đoạn 300 ký tự
        const chunks = splitText(rawContent, 300);
        updateButtons('loading');
        setStatus(`Đang tạo audio (0/${chunks.length} đoạn)...`);

        for (let i = 0; i < chunks.length; i++) {
            if (isStopped) break;
            setStatus(`Đang tạo audio (${i + 1}/${chunks.length} đoạn)...`);
            try {
                const res  = await fetch('/Tts/Speak', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: chunks[i], voice: 'banmai' })
                });
                const data = await res.json();
                if (data.audioUrl) audioQueue.push(data.audioUrl);
            } catch (e) {
                console.warn(`[TTS] Lỗi đoạn ${i + 1}:`, e);
            }
        }

        if (audioQueue.length === 0) {
            setStatus('Lỗi tạo audio!'); updateButtons('stopped'); return;
        }

        setStatus('Đang tải audio...');
        await delay(3000);

        updateButtons('playing');
        await playFrom(0);
    }

    // --- Phát từ index ---
    async function playFrom(index) {
        if (isStopped || index >= audioQueue.length) {
            if (!isStopped) { updateButtons('stopped'); setStatus('Đã đọc xong!'); }
            return;
        }

        currentIndex = index;
        setStatus(`Đang đọc... (${index + 1}/${audioQueue.length})`);

        await new Promise((resolve) => {
            const audio  = new Audio(audioQueue[index]);
            currentAudio = audio;

            audio.onended = async () => {
                currentAudio = null;
                if (!isStopped && !isPaused) {
                    await delay(300);
                    await playFrom(index + 1);
                }
                resolve();
            };

            audio.onerror = async () => {
                currentAudio = null;
                await delay(1500);
                if (!isStopped && !isPaused) await playFrom(index + 1);
                resolve();
            };

            audio.play().catch(async () => {
                currentAudio = null;
                await delay(1500);
                if (!isStopped && !isPaused) await playFrom(index + 1);
                resolve();
            });
        });
    }

    // --- Tạm dừng: dừng audio đang phát, giữ vị trí ---
    function pauseReading() {
        isPaused = true;
        if (currentAudio) {
            currentAudio.pause();
        }
        updateButtons('paused');
        setStatus('Đã tạm dừng — nhấn Tiếp tục để nghe tiếp');
    }

    // --- Tiếp tục từ đoạn đang dừng ---
    async function resumeReading() {
        isPaused = false;
        updateButtons('playing');
        if (currentAudio) {
            // Tiếp tục audio đang pause (nếu còn)
            currentAudio.play().catch(() => {});
        } else {
            // Phát lại từ đoạn hiện tại
            await playFrom(currentIndex);
        }
    }

    // --- Dừng hẳn ---
    function stopReading() {
        isStopped    = true;
        isPaused     = false;
        if (currentAudio) {
            currentAudio.pause();
            currentAudio.src = '';
            currentAudio = null;
        }
        audioQueue   = [];
        currentIndex = 0;
        updateButtons('stopped');
        setStatus('');
    }

    function splitText(text, maxLen) {
        const chunks    = [];
        let remaining   = text.trim();
        while (remaining.length > 0) {
            if (remaining.length <= maxLen) { chunks.push(remaining); break; }
            let cutAt = maxLen;
            for (const p of ['. ', '! ', '? ', ', ', '; ']) {
                const idx = remaining.lastIndexOf(p, maxLen);
                if (idx > maxLen * 0.5) { cutAt = idx + p.length; break; }
            }
            chunks.push(remaining.substring(0, cutAt).trim());
            remaining = remaining.substring(cutAt).trim();
        }
        return chunks.filter(c => c.length > 0);
    }

    function delay(ms) { return new Promise(r => setTimeout(r, ms)); }
    function setStatus(msg) { document.getElementById('tts-status').innerText = msg; }

    function updateButtons(state) {
        const btnPlay  = document.getElementById('btn-play');
        const btnPause = document.getElementById('btn-pause');
        const btnStop  = document.getElementById('btn-stop');

        btnPlay.style.display  = 'none';
        btnPause.style.display = 'none';
        btnStop.style.display  = 'none';
        btnPlay.disabled = false;

        if (state === 'loading') {
            btnPlay.style.display = 'inline-block';
            btnPlay.disabled      = true;
            btnPlay.innerHTML     = '<i class="fa fa-spinner fa-spin mr-1"></i> Đang tải...';
            btnStop.style.display = 'inline-block';
        } else if (state === 'playing') {
            btnPause.style.display = 'inline-block';
            btnStop.style.display  = 'inline-block';
        } else if (state === 'paused') {
            btnPlay.style.display  = 'inline-block';
            btnPlay.innerHTML      = '<i class="fa fa-play mr-1"></i> Tiếp tục';
            btnStop.style.display  = 'inline-block';
        } else {
            btnPlay.style.display = 'inline-block';
            btnPlay.innerHTML     = '<i class="fa fa-volume-up mr-1"></i> Đọc bài viết';
        }
    }

    // Sửa lại onclick của nút Play để xử lý cả resume
    document.getElementById('btn-play').onclick = startReading;

    // ===== Fix lazy-loaded images + blank spaces trong nội dung bài viết =====
    (function fixLazyImages() {
        const entryContent = document.querySelector('.entry-content');
        if (!entryContent) return;

        // Xóa height inline trên TẤT CẢ wrapper ảnh phổ biến (VnExpress, TuoiTre, DanTri...)
        const wrapperSel = 'figure, picture, .VCSortableInPreviewMode, .box_content_detail, ' +
                           '.fig-picture, [data-type="Photo"], .article-body-image-wrapper, ' +
                           '.item_slide_show, .imagefull, .image_article';
        entryContent.querySelectorAll(wrapperSel).forEach(el => {
            el.style.height    = '';
            el.style.minHeight = '';
            el.style.paddingTop = '';
            el.removeAttribute('height');
        });

        // Khi ảnh lỗi: ẩn ảnh + collapse wrapper để không còn khoảng trắng
        function collapseWrapper(img) {
            let el = img.parentElement;
            while (el && el !== entryContent) {
                el.style.height    = '';
                el.style.minHeight = '';
                el.style.paddingTop = '';
                el.removeAttribute('height');
                if (el.tagName === 'FIGURE' || el.tagName === 'PICTURE') {
                    el.style.display = 'none';
                    return;
                }
                el = el.parentElement;
            }
        }

        entryContent.querySelectorAll('img').forEach(img => {
            const src     = (img.getAttribute('src') || '').trim();
            const isEmpty = !src || src === 'about:blank'
                         || src === window.location.href
                         || src.startsWith('data:image/gif');

            if (isEmpty) {
                const real = img.dataset.src
                          || img.dataset.original
                          || img.dataset.lazySrc
                          || img.dataset.lazy
                          || img.getAttribute('data-src')
                          || img.getAttribute('data-original');
                if (real) {
                    img.setAttribute('referrerpolicy', 'no-referrer');
                    img.src = real;
                } else {
                    img.classList.add('img-broken');
                    collapseWrapper(img);
                }
            }

            // Ảnh lỗi load (404, hotlink blocked...) → ẩn + collapse wrapper
            img.addEventListener('error', function () {
                this.classList.add('img-broken');
                collapseWrapper(this);
            });

            img.removeAttribute('width');
            img.removeAttribute('height');
        });
    })();

    window.addEventListener('beforeunload', stopReading);

    // --- Lưu / bỏ lưu bài viết ---
    let _isSaved = @(isSaved ? "true" : "false");

    async function toggleSave(postId) {
        const btn     = document.getElementById('btn-save-post');
        const msg     = document.getElementById('save-msg');
        const action  = _isSaved ? '/SavedPosts/Remove' : '/SavedPosts/Save';
        const token   = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        btn.disabled = true;
        try {
            const res  = await fetch(action, {
                method : 'POST',
                headers: {
                    'Content-Type'           : 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `postId=${postId}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await res.json();
            msg.textContent = data.message;

            if (data.success) {
                _isSaved = !_isSaved;
                btn.className = _isSaved ? 'btn btn-sm btn-warning' : 'btn btn-sm btn-outline-warning';
                btn.innerHTML = `<i class="fa ${_isSaved ? 'fa-bookmark' : 'fa-bookmark-o'} mr-1"></i>${_isSaved ? 'Đã lưu' : 'Lưu bài viết'}`;
            }
        } catch (e) {
            msg.textContent = 'Lỗi kết nối!';
        }
        btn.disabled = false;
        setTimeout(() => msg.textContent = '', 3000);
    }
</script>
}