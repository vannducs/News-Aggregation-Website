@model NewsAggregator.Models.ViewModels.SearchViewModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Keyword) ? "Tìm kiếm bài viết" : $"Tìm kiếm: {Model.Keyword}";
}

<style>
.search-hero{background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);padding:52px 0 38px;color:#fff;text-align:center}
.search-hero h1{font-size:2rem;font-weight:800;margin-bottom:6px}
.search-hero p{color:rgba(255,255,255,.6);margin-bottom:24px}
.search-box-wrap{position:relative;max-width:700px;margin:0 auto}
.search-input-row{display:flex;align-items:center;background:#fff;border-radius:50px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.3)}
.search-input-row i{color:#aaa;padding:0 14px 0 20px}
.search-input-row input{flex:1;border:none;outline:none;padding:15px 8px;font-size:1rem;color:#333}
.search-input-row button{background:#e43f5a;color:#fff;border:none;padding:15px 28px;font-weight:700;cursor:pointer;font-size:.95rem;transition:.2s}
.search-input-row button:hover{background:#c0392b}
/* live dropdown */
.live-dropdown{position:absolute;top:calc(100% + 8px);left:0;right:0;background:#fff;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,.18);z-index:999;overflow:hidden;display:none}
.live-dropdown.show{display:block}
.live-item{display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;transition:.15s;border-bottom:1px solid #f0f0f0;text-decoration:none}
.live-item:hover,.live-item.focused{background:#fff5f7}
.live-item:last-of-type{border-bottom:none}
.live-img{width:52px;height:40px;object-fit:cover;border-radius:6px;flex-shrink:0;background:#eee}
.live-cat{font-size:.68rem;font-weight:700;color:#e43f5a;text-transform:uppercase;letter-spacing:.5px}
.live-title{font-size:.85rem;font-weight:600;color:#222;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.live-meta{font-size:.72rem;color:#aaa;margin-top:2px}
.live-footer{padding:10px 16px;background:#fafafa;font-size:.8rem;color:#888;display:flex;justify-content:space-between;align-items:center}
.live-footer a{color:#e43f5a;font-weight:600;text-decoration:none}
.live-footer a:hover{text-decoration:underline}
.live-skeleton{padding:10px 16px}
.skel{background:linear-gradient(90deg,#eee 25%,#f5f5f5 50%,#eee 75%);background-size:200%;border-radius:4px;height:12px;margin-bottom:6px;animation:skel 1.2s infinite}
@@keyframes skel{0%{background-position:200% 0}100%{background-position:-200% 0}}
/* filter bar */
.filter-bar{background:#f8f9fa;border-bottom:1px solid #e0e0e0;padding:12px 0;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.filter-row{display:flex;align-items:center;flex-wrap:wrap;gap:10px}
.filter-group{display:flex;align-items:center;flex-wrap:wrap;gap:6px}
.filter-label{font-size:.8rem;font-weight:700;color:#666;white-space:nowrap}
.chip{display:inline-block;padding:4px 12px;border-radius:20px;font-size:.78rem;font-weight:500;color:#555;background:#fff;border:1px solid #ddd;transition:.18s;text-decoration:none;white-space:nowrap}
.chip:hover,.chip.active{background:#e43f5a;color:#fff;border-color:#e43f5a;text-decoration:none}
.chip-date-wrap{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.date-input{padding:4px 8px;border:1px solid #ddd;border-radius:6px;font-size:.78rem;outline:none;cursor:pointer}
.date-input:focus{border-color:#e43f5a}
.filter-right{margin-left:auto}
/* results */
.results-section{padding:32px 0}
.result-meta{font-size:.9rem;color:#555;margin-bottom:20px}
.result-meta strong{color:#e43f5a}
/* card */
.s-card{background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08);transition:.22s;height:100%;display:flex;flex-direction:column}
.s-card:hover{transform:translateY(-5px);box-shadow:0 10px 30px rgba(0,0,0,.14)}
.s-card-img-wrap{position:relative;overflow:hidden}
.s-card-img{width:100%;height:175px;object-fit:cover;display:block;transition:.3s}
.s-card:hover .s-card-img{transform:scale(1.06)}
.s-card-cat{position:absolute;top:10px;left:10px;background:#e43f5a;color:#fff;font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;padding:3px 9px;border-radius:4px}
.s-card-cat a{color:#fff;text-decoration:none}
.s-badge-cmt{position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);color:#fff;font-size:.72rem;padding:2px 8px;border-radius:10px}
.s-card-body{padding:14px 16px 16px;display:flex;flex-direction:column;flex:1}
.s-card-title{font-size:.9rem;font-weight:700;line-height:1.4;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.s-card-title a{color:#1a1a2e;text-decoration:none}
.s-card-title a:hover{color:#e43f5a}
.s-card-abs{font-size:.78rem;color:#888;line-height:1.5;flex:1;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.s-card-meta{display:flex;flex-wrap:wrap;gap:8px;font-size:.73rem;color:#aaa;margin-bottom:10px}
.s-card-link{font-size:.8rem;font-weight:700;color:#e43f5a;text-decoration:none;margin-top:auto}
.s-card-link:hover{color:#c0392b}
/* pagination */
.pager .page-link{border-radius:6px!important;margin:0 2px;color:#e43f5a;border-color:#e0e0e0}
.pager .page-item.active .page-link{background:#e43f5a;border-color:#e43f5a;color:#fff}
.pager .page-link:hover{background:#ffeef1}
/* empty */
.empty-state{text-align:center;padding:60px 0}
.empty-icon{font-size:4rem;color:#ddd}
/* highlight */
mark{background:#fff3cd;padding:0 2px;border-radius:2px;font-weight:600}
@@media(max-width:768px){.filter-right{margin-left:0}.search-hero h1{font-size:1.4rem}.search-input-row button{padding:15px 14px}}
</style>

@* ===== HERO ===== *@
<div class="search-hero">
  <div class="container">
    <h1><i class="fa fa-search mr-2"></i>Tìm kiếm bài viết</h1>
    <p>Khám phá hàng nghìn bài viết từ các nguồn tin uy tín</p>
    <form asp-controller="Search" asp-action="Index" method="get" id="searchForm">
      <input type="hidden" name="categoryID" value="@Model.CategoryID" id="hidCat"/>
      <input type="hidden" name="sortBy"     value="@Model.SortBy"     id="hidSort"/>
      <input type="hidden" name="dateRange"  value="@Model.DateRange"  id="hidRange"/>
      <input type="hidden" name="dateFrom"   value="@Model.DateFrom"   id="hidFrom"/>
      <input type="hidden" name="dateTo"     value="@Model.DateTo"     id="hidTo"/>
      <div class="search-box-wrap">
        <div class="search-input-row">
          <i class="fa fa-search"></i>
          <input type="text" name="keyword" id="searchKeyword"
                 value="@Model.Keyword" autocomplete="off"
                 placeholder="Nhập từ khóa tìm kiếm..." />
          <button type="submit"><i class="fa fa-search mr-1"></i>Tìm kiếm</button>
        </div>
        <div class="live-dropdown" id="liveDropdown"></div>
      </div>
    </form>
  </div>
</div>

@* ===== FILTER BAR ===== *@
<div class="filter-bar">
  <div class="container">
    <div class="filter-row">
      <div class="filter-group">
        <span class="filter-label"><i class="fa fa-folder-o mr-1"></i>Danh mục:</span>
        <a href="@Url.Action("Index","Search",new{keyword=Model.Keyword,sortBy=Model.SortBy,page=1})"
           class="chip @(Model.CategoryID==null?"active":"")">Tất cả</a>
        @foreach(var c in Model.Categories){
          <a href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=c.MenuID,sortBy=Model.SortBy,page=1})"
             class="chip @(Model.CategoryID==c.MenuID?"active":"")">@c.MenuName</a>
        }
      </div>
      <div class="filter-group filter-right">
        <span class="filter-label"><i class="fa fa-calendar mr-1"></i>Thời gian:</span>
        @foreach(var (val,lbl) in new[]{("","Tất cả"),("today","Hôm nay"),("week","7 ngày"),("month","30 ngày")}){
          <a href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=Model.SortBy,dateRange=val,page=1})"
             class="chip @(Model.DateRange==val&&Model.DateRange!="custom"?"active":"")">@lbl</a>
        }
        <span class="chip-date-wrap">
          <input type="date" id="dpFrom" class="date-input" value="@Model.DateFrom" title="Từ ngày"/>
          <span style="font-size:.78rem;color:#888">—</span>
          <input type="date" id="dpTo" class="date-input" value="@Model.DateTo" title="Đến ngày"/>
          <button onclick="applyCustomDate()" class="chip active" style="cursor:pointer;border:none">
            <i class="fa fa-filter"></i> Lọc
          </button>
        </span>
        <span class="filter-label ml-3"><i class="fa fa-sort mr-1"></i>Sắp xếp:</span>
        @foreach(var (val,lbl,ico) in new[]{("newest","Mới nhất","fa-clock-o"),("oldest","Cũ nhất","fa-history"),("popular","Nổi bật","fa-fire"),("title","A→Z","fa-sort-alpha-asc")}){
          <a href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=val,dateRange=Model.DateRange,dateFrom=Model.DateFrom,dateTo=Model.DateTo,page=1})"
             class="chip @(Model.SortBy==val?"active":"")">
            <i class="fa @ico mr-1"></i>@lbl
          </a>
        }
      </div>
    </div>
  </div>
</div>

@* ===== RESULTS ===== *@
<section class="results-section">
  <div class="container">
    <div class="result-meta mb-3">
      @if(Model.TotalResults==0){
        <span>Không tìm thấy kết quả nào</span>
      } else {
        <span><strong>@Model.TotalResults</strong> kết quả
          @if(!string.IsNullOrWhiteSpace(Model.Keyword)){
            <span> cho "<strong class="text-danger">@Model.Keyword</strong>"</span>
          }
          @if(Model.TotalPages>1){
            <span class="text-muted"> — trang @Model.CurrentPage/@Model.TotalPages</span>
          }
        </span>
      }
    </div>

    @if(Model.Results.Any()){
      <div class="row">
        @foreach(var post in Model.Results){
          var cmt = Model.GetCommentCount(post.PostID);
          <div class="col-md-6 col-lg-3 mb-4">
            <article class="s-card">
              <div class="s-card-img-wrap">
                <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.PostID">
                  <img class="s-card-img"
                       src="@(string.IsNullOrWhiteSpace(post.Images)?"/images/news/news-07.jpg":post.Images)"
                       alt="@post.Title" onerror="this.src='/images/news/news-07.jpg'"/>
                </a>
                <span class="s-card-cat">
                  <a asp-controller="Home" asp-action="Category" asp-route-id="@post.MenuID">
                    @(post.Menu?.MenuName??"Tin tức")
                  </a>
                </span>
                @if(cmt>0){
                  <span class="s-badge-cmt"><i class="fa fa-comment-o mr-1"></i>@cmt</span>
                }
              </div>
              <div class="s-card-body">
                <h2 class="s-card-title">
                  <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.PostID">@post.Title</a>
                </h2>
                <p class="s-card-abs">
                  @(string.IsNullOrWhiteSpace(post.Abstract)?"Xem chi tiết bài viết...":post.Abstract)
                </p>
                <div class="s-card-meta">
                  <span><i class="fa fa-clock-o mr-1"></i>@post.CreatedDate.ToString("dd/MM/yyyy")</span>
                  @if(!string.IsNullOrWhiteSpace(post.Author)){
                    <span><i class="fa fa-user mr-1"></i>@post.Author</span>
                  }
                  @if(post.ViewCount>0){
                    <span><i class="fa fa-eye mr-1"></i>@post.ViewCount</span>
                  }
                  @if(cmt>0){
                    <span><i class="fa fa-comment-o mr-1"></i>@cmt bình luận</span>
                  }
                </div>
                <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.PostID" class="s-card-link">
                  Đọc bài <i class="fa fa-arrow-right ml-1"></i>
                </a>
              </div>
            </article>
          </div>
        }
      </div>

      @if(Model.TotalPages>1){
        <nav class="pager mt-3" aria-label="Phân trang">
          <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage?"disabled":"")">
              <a class="page-link" href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=Model.SortBy,dateRange=Model.DateRange,dateFrom=Model.DateFrom,dateTo=Model.DateTo,page=Model.CurrentPage-1})">
                <i class="fa fa-chevron-left"></i>
              </a>
            </li>
            @{int sp=Math.Max(1,Model.CurrentPage-2),ep=Math.Min(Model.TotalPages,sp+4);sp=Math.Max(1,ep-4);}
            @if(sp>1){
              <li class="page-item"><a class="page-link" href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=Model.SortBy,dateRange=Model.DateRange,dateFrom=Model.DateFrom,dateTo=Model.DateTo,page=1})">1</a></li>
              @if(sp>2){<li class="page-item disabled"><span class="page-link">…</span></li>}
            }
            @for(int i=sp;i<=ep;i++){
              <li class="page-item @(i==Model.CurrentPage?"active":"")">
                <a class="page-link" href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=Model.SortBy,dateRange=Model.DateRange,dateFrom=Model.DateFrom,dateTo=Model.DateTo,page=i})">@i</a>
              </li>
            }
            @if(ep<Model.TotalPages){
              @if(ep<Model.TotalPages-1){<li class="page-item disabled"><span class="page-link">…</span></li>}
              <li class="page-item"><a class="page-link" href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=Model.SortBy,dateRange=Model.DateRange,dateFrom=Model.DateFrom,dateTo=Model.DateTo,page=Model.TotalPages})">@Model.TotalPages</a></li>
            }
            <li class="page-item @(!Model.HasNextPage?"disabled":"")">
              <a class="page-link" href="@Url.Action("Index","Search",new{keyword=Model.Keyword,categoryID=Model.CategoryID,sortBy=Model.SortBy,dateRange=Model.DateRange,dateFrom=Model.DateFrom,dateTo=Model.DateTo,page=Model.CurrentPage+1})">
                <i class="fa fa-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      }
    } else {
      <div class="empty-state">
        <i class="fa fa-search empty-icon"></i>
        <h3 class="mt-3">Không tìm thấy bài viết nào</h3>
        <p class="text-muted">
          @if(!string.IsNullOrWhiteSpace(Model.Keyword)){
            <span>Không có kết quả cho "<strong>@Model.Keyword</strong>". </span>
          }
          Hãy thử từ khóa khác hoặc điều chỉnh bộ lọc.
        </p>
        <a asp-controller="Search" asp-action="Index" class="btn btn-danger mt-2">
          <i class="fa fa-list mr-1"></i>Xem tất cả bài viết
        </a>
      </div>
    }
  </div>
</section>

@section Scripts {
<script>
(function(){
  const inp = document.getElementById('searchKeyword');
  const box = document.getElementById('liveDropdown');
  let timer, idx = -1, items = [];

  function skeleton(){
    box.innerHTML = '<div class="live-skeleton">'
      + [1,2,3].map(()=>'<div class="skel" style="width:80%"></div><div class="skel" style="width:55%"></div>').join('')
      + '</div>';
    box.classList.add('show');
  }

  function highlight(text, kw){
    if(!kw) return text;
    const re = new RegExp('('+kw.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')', 'gi');
    return text.replace(re,'<mark>$1</mark>');
  }

  function render(data, kw){
    const {suggestions, totalCount} = data;
    if(!suggestions.length){ box.classList.remove('show'); return; }
    let html = suggestions.map((s,i) => {
      const img = s.image
        ? `<img class="live-img" src="${s.image}" onerror="this.src='/images/news/news-07.jpg'" alt=""/>`
        : `<div class="live-img"></div>`;
      return `<a class="live-item" href="/Posts/Details/${s.id}" data-i="${i}">
        ${img}
        <div style="flex:1;min-width:0">
          <div class="live-cat">${s.category}</div>
          <div class="live-title">${highlight(s.title, kw)}</div>
          <div class="live-meta"><i class="fa fa-clock-o mr-1"></i>${s.date} &nbsp; <i class="fa fa-eye mr-1"></i>${s.views}</div>
        </div></a>`;
    }).join('');
    const more = totalCount > suggestions.length
      ? `<span>${totalCount} kết quả</span><a href="/Search/Index?keyword=${encodeURIComponent(kw)}">Xem tất cả →</a>`
      : `<span>${totalCount} kết quả</span>`;
    html += `<div class="live-footer">${more}</div>`;
    box.innerHTML = html;
    box.classList.add('show');
    items = box.querySelectorAll('.live-item');
  }

  async function fetchSuggestions(kw){
    skeleton();
    try{
      const r = await fetch(`/Search/LiveSearch?keyword=${encodeURIComponent(kw)}`);
      const d = await r.json();
      render(d, kw);
    } catch(e){ box.classList.remove('show'); }
  }

  inp.addEventListener('input', function(){
    const v = this.value.trim();
    idx = -1;
    clearTimeout(timer);
    if(v.length < 2){ box.classList.remove('show'); return; }
    timer = setTimeout(() => fetchSuggestions(v), 220);
  });

  inp.addEventListener('keydown', function(e){
    if(!box.classList.contains('show')) return;
    if(e.key === 'ArrowDown'){ e.preventDefault(); idx = Math.min(idx+1, items.length-1); setFocus(); }
    else if(e.key === 'ArrowUp'){ e.preventDefault(); idx = Math.max(idx-1, -1); setFocus(); }
    else if(e.key === 'Enter' && idx >= 0){ e.preventDefault(); items[idx].click(); }
    else if(e.key === 'Escape'){ box.classList.remove('show'); idx = -1; }
  });

  function setFocus(){
    items.forEach((el,i)=> el.classList.toggle('focused', i===idx));
    if(idx >= 0) items[idx].scrollIntoView({block:'nearest'});
  }

  document.addEventListener('click', function(e){
    if(!inp.contains(e.target) && !box.contains(e.target)) box.classList.remove('show');
  });

  // Custom date range
  window.applyCustomDate = function(){
    const from = document.getElementById('dpFrom').value;
    const to   = document.getElementById('dpTo').value;
    if(!from || !to){ alert('Vui lòng chọn đầy đủ khoảng ngày.'); return; }
    document.getElementById('hidRange').value = 'custom';
    document.getElementById('hidFrom').value  = from;
    document.getElementById('hidTo').value    = to;
    document.getElementById('searchForm').submit();
  };
})();
</script>
}
