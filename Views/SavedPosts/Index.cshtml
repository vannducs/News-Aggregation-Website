@model List<NewsAggregator.Models.SavedPost>
@{
    ViewData["Title"] = "Bài viết đã lưu";
}

<section class="section-padding">
    <div class="container">
        <h2 class="news-title mb-4">
            <span><i class="fa fa-bookmark mr-2"></i>Bài viết đã lưu</span>
        </h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa fa-bookmark-o fa-3x text-muted mb-3"></i>
                <p class="text-muted">Bạn chưa lưu bài viết nào.</p>
                <a asp-controller="News" asp-action="Index" class="btn btn-primary">
                    Khám phá tin tức
                </a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    var post = item.Post;
                    if (post == null) continue;
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(post.Images))
                            {
                                <a asp-controller="News" asp-action="Detail" asp-route-id="@post.PostID">
                                    <img src="@post.Images" class="card-img-top"
                                         alt="@post.Title"
                                         style="height:180px;object-fit:cover;">
                                </a>
                            }
                            <div class="card-body d-flex flex-column">
                                @if (post.Menu != null)
                                {
                                    <span class="badge badge-primary mb-2" style="width:fit-content">
                                        @post.Menu.MenuName
                                    </span>
                                }
                                <h6 class="card-title">
                                    <a asp-controller="News" asp-action="Detail" asp-route-id="@post.PostID"
                                       class="text-dark">
                                        @post.Title
                                    </a>
                                </h6>
                                <p class="card-text text-muted small flex-grow-1">
                                    @(post.Abstract?.Length > 100 ? post.Abstract[..100] + "..." : post.Abstract)
                                </p>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                    <small class="text-muted">
                                        <i class="fa fa-bookmark mr-1"></i>
                                        Lưu lúc @item.SavedAt.ToString("dd/MM/yyyy")
                                    </small>
                                    <form asp-controller="SavedPosts" asp-action="RemoveFromList" method="post"
                                          onsubmit="return confirm('Xóa khỏi danh sách đã lưu?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="postId" value="@post.PostID" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fa fa-times"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
