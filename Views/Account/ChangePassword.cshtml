@model NewsAggregator.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Doi mat khau";
}

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                @if (TempData["PasswordMessage"] is string passwordMessage)
                {
                    <div class="alert alert-success">@passwordMessage</div>
                }

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="mb-3">Doi mat khau</h2>
                        <form asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="form-group mb-3">
                                <label asp-for="CurrentPassword" class="form-label">Mat khau hien tai</label>
                                <input asp-for="CurrentPassword" class="form-control" />
                                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="NewPassword" class="form-label">Mat khau moi</label>
                                <input asp-for="NewPassword" class="form-control" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>
                            <div class="form-group mb-4">
                                <label asp-for="ConfirmPassword" class="form-label">Nhap lai mat khau moi</label>
                                <input asp-for="ConfirmPassword" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Cap nhat mat khau</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
