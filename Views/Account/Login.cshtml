@model NewsAggregator.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Dang nhap";
}

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="mb-3">Dang nhap</h2>
                        <p class="text-muted">Su dung tai khoan da tao trong he thong de vao trang quan tri hoac binh luan voi thong tin thanh vien.</p>

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <input asp-for="ReturnUrl" type="hidden" />
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="form-group mb-3">
                                <label asp-for="UserNameOrEmail" class="form-label">Ten dang nhap hoac email</label>
                                <input asp-for="UserNameOrEmail" class="form-control" />
                                <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Password" class="form-label">Mat khau</label>
                                <input asp-for="Password" class="form-control" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary btn-block w-100">Dang nhap</button>
                        </form>

                        <div class="mt-4 small text-muted">
                            Tai khoan admin seed mac dinh: <strong>anhbao</strong> / <strong>123456</strong>
                        </div>
                        <div class="mt-2 small">
                            Chua co tai khoan? <a asp-action="Register">Dang ky ngay</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
