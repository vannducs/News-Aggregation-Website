@model IReadOnlyCollection<NewsAggregator.Models.ViewModels.MenuNodeViewModel>
@{
    var currentPath = Context.Request.Path.Value ?? "/";
    bool IsActive(string? url)
    {
        if (string.IsNullOrWhiteSpace(url) || url == "#")
        {
            return false;
        }

        if (!Uri.TryCreate(url, UriKind.RelativeOrAbsolute, out var uri))
        {
            return false;
        }

        var path = uri.IsAbsoluteUri ? uri.AbsolutePath : url;
        path = path.Split('?', '#')[0];

        if (string.Equals(path, "/", StringComparison.OrdinalIgnoreCase))
        {
            return string.Equals(currentPath, "/", StringComparison.OrdinalIgnoreCase);
        }

        return string.Equals(currentPath, path, StringComparison.OrdinalIgnoreCase) ||
               currentPath.StartsWith(path + "/", StringComparison.OrdinalIgnoreCase);
    }
}

<div class="main-navbar clearfix bg-dark">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <nav class="navbar navbar-expand-lg site-main-nav navigation">
                    <a class="navbar-brand d-lg-none" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logos/footer-logo.png" alt="logo" />
                    </a>

                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="fa fa-bars"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav mr-auto">
                            @foreach (var menu in Model)
                            {
                                var isActive = IsActive(menu.Url) || menu.Children.Any(child => IsActive(child.Url));

                                if (menu.Children.Any())
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle @(isActive ? "active" : null)" href="@menu.Url" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                            @menu.MenuName
                                        </a>
                                        <div class="dropdown-menu">
                                            @foreach (var child in menu.Children)
                                            {
                                                <a class="dropdown-item @(IsActive(child.Url) ? "active" : null)" href="@child.Url">@child.MenuName</a>
                                            }
                                        </div>
                                    </li>
                                }
                                else
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(isActive ? "active" : null)" href="@menu.Url">@menu.MenuName</a>
                                    </li>
                                }
                            }
                        </ul>
                        <div class="nav-search ml-auto d-none d-lg-block">
                            <a asp-controller="Search" asp-action="Index" class="text-white">
                                <i class="fa fa-search"></i>
                            </a>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
    </div>
</div>
