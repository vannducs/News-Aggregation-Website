    </button>
    <button class="vne-all-btn" id="vneAllBtn" title="Tất cả chuyên mục">
        <i class="fa fa-bars"></i>
    </button>
    <div class="vne-all-dropdown" id="vneAllDropdown">
        <ul>
            <li><a asp-controller="News" asp-action="Index">Trang chủ</a></li>
            @if (ViewBag.Menus != null)
            {
                foreach (var menu in ViewBag.Menus)
                {
                    if (menu.MenuName != "Trang chủ")
                    {
                        <li><a asp-controller="News" asp-action="Category" asp-route-id="@menu.MenuID">@menu.MenuName</a></li>
                    }
                }
            }
        </ul>
    </div>
</nav>

</div>@* end .sticky-navs *@

