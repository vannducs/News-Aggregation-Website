<html lang="en">

<head>
    <meta charset="utf-8">
    <title>@(ViewData["Title"] is string title ? $"{title} - NewsBit" : "NewsBit")</title>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- theme meta -->
    <meta name="theme-name" content="newsbit" />

    <!--Favicon-->
    <link rel="shortcut icon" href="~/images/favicon.ico" type="image/x-icon">
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png">

    <!-- THEME CSS
	================================================== -->
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/plugins/bootstrap/css/bootstrap.min.css">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="~/plugins/font-awesome/css/font-awesome.min.css">
    <!-- Slick Carousel -->
    <link rel="stylesheet" href="~/plugins/slick-carousel/slick.css">
    <link rel="stylesheet" href="~/plugins/slick-carousel/slick-theme.css">
    <!-- main stylesheet -->
    <link rel="stylesheet" href="~/css/style.css">
    <!-- Google Font: Be Vietnam Pro (cho tiêu đề) -->
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- Google Material Symbols (dùng cho weather bar) -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" rel="stylesheet">

    <style>
        h1, h2, h3, .post-title, .news-title span { font-family: 'Be Vietnam Pro', sans-serif !important; }

        /* ===== STICKY WRAPPER — giữ cả 2 navbar dính cùng nhau ===== */
        .sticky-navs {
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* ===== SOURCE NAVBAR ===== */
        .src-navbar {
            background: #2a2a2a;
            display: flex;
            align-items: stretch;
            height: 40px;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }
        .src-nav-inner {
            flex: 1;
            overflow: hidden;
            min-width: 0;
        }
        .src-nav-list {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            overflow-x: auto;
            scrollbar-width: none;
            -ms-overflow-style: none;
            scroll-behavior: smooth;
            height: 100%;
            align-items: center;
        }
        .src-nav-list::-webkit-scrollbar { display: none; }
        .src-nav-list li { flex-shrink: 0; }
        .src-nav-list li a {
            display: block;
            padding: 0 14px;
            line-height: 38px;
            color: #aaa;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            letter-spacing: 0.3px;
            text-transform: uppercase;
            border-bottom: 2px solid transparent;
            transition: color .2s, border-color .2s;
        }
        .src-nav-list li a:hover,
        .src-nav-list li.src-active a {
            color: #fff;
            border-bottom-color: #4dabf7;
        }
        .src-search-area {
            display: flex;
            align-items: center;
            padding: 0 8px;
            border-left: 1px solid rgba(255,255,255,.12);
            flex-shrink: 0;
        }
        .src-search-form { display: flex; align-items: center; }
        .src-search-input {
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.15);
            border-right: none;
            border-radius: 3px 0 0 3px;
            color: #fff;
            font-size: 12px;
            padding: 0 10px;
            width: 150px;
            height: 28px;
            outline: none;
            transition: background .2s, width .3s;
        }
        .src-search-input::placeholder { color: rgba(255,255,255,.45); }
        .src-search-input:focus {
            background: rgba(255,255,255,.15);
            width: 200px;
        }
        .src-search-btn {
            background: #e53935;
            border: none;
            border-radius: 0 3px 3px 0;
            color: #fff;
            padding: 0 11px;
            height: 28px;
            cursor: pointer;
            font-size: 12px;
            transition: background .2s;
            flex-shrink: 0;
        }
        .src-search-btn:hover { background: #c62828; }

        /* ===== CATEGORY NAVBAR VNEXPRESS STYLE ===== */
        .vne-navbar {
            background: #1a1a1a;
            display: flex;
            align-items: stretch;
            border-bottom: 2px solid #c0392b;
        }
        .vne-nav-inner {
            flex: 1;
            overflow: hidden;
            position: relative;
        }
        .vne-nav-list {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            overflow-x: auto;
            scrollbar-width: none;
            -ms-overflow-style: none;
            scroll-behavior: smooth;
        }
        .vne-nav-list::-webkit-scrollbar { display: none; }
        .vne-nav-list li { flex-shrink: 0; }
        .vne-nav-list li a {
            display: block;
            padding: 13px 13px;
            color: #ccc;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            letter-spacing: 0.4px;
            text-transform: uppercase;
            transition: color .2s;
            border-bottom: 3px solid transparent;
        }
        .vne-nav-list li a:hover,
        .vne-nav-list li.vne-active a {
            color: #fff;
            border-bottom-color: #e53935;
        }
        .vne-scroll-btn,
        .vne-all-btn {
            background: #1a1a1a;
            border: none;
            border-left: 1px solid rgba(255,255,255,.12);
            color: #ccc;
            padding: 0 14px;
            cursor: pointer;
            font-size: 18px;
            transition: background .2s, color .2s;
            flex-shrink: 0;
        }
        .vne-scroll-btn:hover, .vne-all-btn:hover {
            background: rgba(255,255,255,.1);
            color: #fff;
        }
        .vne-scroll-btn.vne-hidden { display: none; }
        /* All-categories dropdown */
        .vne-all-dropdown {
            display: none;
            position: absolute;
            top: 100%;
            right: 0;
            background: #fff;
            border: 1px solid #ddd;
            box-shadow: 0 6px 20px rgba(0,0,0,.15);
            z-index: 1002;
            min-width: 280px;
            padding: 16px 20px;
        }
        .vne-all-dropdown.vne-open { display: block; }
        .vne-all-dropdown ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2px 12px;
        }
        .vne-all-dropdown ul li a {
            display: block;
            padding: 7px 4px;
            color: #333;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            border-bottom: 1px solid #f0f0f0;
        }
        .vne-all-dropdown ul li a:hover { color: #e53935; }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>

<div class="trending-bar-dark hidden-xs">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-auto pr-3" style="border-right:1px solid rgba(255,255,255,.2)">
                <a asp-controller="News" asp-action="Index">
                    <img src="~/images/logos/footer-logo.png" alt="NewsBit"
                         style="max-height:40px; width:auto; display:block;">
                </a>
            </div>
            @* ── Weather bar — hiện bên phải logo ── *@
            <div class="col-auto pl-3">
                @{ var weather = await WeatherService.GetWeatherAsync(); }
                <partial name="_WeatherBar" model="weather" />
            </div>
            <div class="col top-nav-social-lists text-right ml-auto">
                <ul class="list-unstyled mt-4 mt-lg-0">
                    <li>
                        @* Login/Logout của Bao — sp1 *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-white mr-3">
                                Xin chào, @(User.FindFirst("FullName")?.Value ?? User.Identity.Name)
                            </span>
                            <a asp-controller="Account" asp-action="Profile" class="text-white mr-3">
                                Hồ sơ
                            </a>
                            @if (User.IsInRole(NewsAggregator.Models.UserRoles.Admin) ||
                                 User.IsInRole(NewsAggregator.Models.UserRoles.Editor) ||
                                 User.IsInRole(NewsAggregator.Models.UserRoles.Moderator))
                            {
                                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                                   class="text-white mr-3">Admin</a>
                            }
                            <form asp-controller="Account" asp-action="Logout"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-link text-white p-0 mr-3"
                                        style="vertical-align: baseline;">
                                    Đăng xuất
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="text-white mr-3">
                                Đăng nhập
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="text-white mr-3">
                                Đăng ký
                            </a>
                        }

                        <a href="#"><span class="social-icon"><i class="fa fa-facebook-f"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-twitter"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-google-plus"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-youtube"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-linkedin"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-pinterest-p"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-rss"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-github"></i></span></a>
                        <a href="#"><span class="social-icon"><i class="fa fa-reddit-alien"></i></span></a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>


@* ===== STICKY WRAPPER: SOURCE NAVBAR + CATEGORY NAVBAR ===== *@
<div class="sticky-navs">

@* Thanh nguồn báo (trên) *@
<nav class="src-navbar">
    <div class="src-nav-inner">
        <ul class="src-nav-list" id="srcNavList">
            <li>
                <a asp-controller="News" asp-action="Index">Tất cả</a>
            </li>
            @await Component.InvokeAsync("SourceNav")
