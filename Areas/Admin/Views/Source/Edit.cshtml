@model NewsAggregator.Models.Source
@{
    ViewData["Title"] = "Sửa nguồn báo";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main class="app-main">
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-6">
                    <h3 class="mb-0">Sửa nguồn báo</h3>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-end">
                        <li class="breadcrumb-item">
                            <a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a>
                        </li>
                        <li class="breadcrumb-item">
                            <a asp-area="Admin" asp-controller="Source" asp-action="Index">
                                Nguồn báo
                            </a>
                        </li>
                        <li class="breadcrumb-item active">Sửa</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="app-content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">
                                Chỉnh sửa: <strong>@Model.SourceName</strong>
                            </h3>
                        </div>
                        <div class="card-body">
                            <form asp-area="Admin" asp-controller="Source"
                                  asp-action="Edit" asp-route-id="@Model.SourceID"
                                  method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()

                                <input asp-for="SourceID" type="hidden" />

                                <div class="mb-3">
                                    <label asp-for="SourceName" class="form-label fw-semibold">
                                        Tên nguồn báo <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SourceName" class="form-control">
                                    <span asp-validation-for="SourceName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="RssUrl" class="form-label fw-semibold">
                                        RSS Feed URL <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RssUrl" class="form-control">
                                    <span asp-validation-for="RssUrl" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="WebsiteUrl" class="form-label fw-semibold">
                                        Website URL
                                    </label>
                                    <input asp-for="WebsiteUrl" class="form-control">
                                    <span asp-validation-for="WebsiteUrl" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Logo</label>

                                    @* Giữ LogoUrl cũ khi không upload file mới *@
                                    <input asp-for="LogoUrl" type="hidden" />

                                    @* Preview logo hiện tại *@
                                    <div class="mb-2" id="logoPreviewWrap"
                                         style="@(string.IsNullOrEmpty(Model.LogoUrl) ? "display:none" : "")">
                                        <img id="logoPreview"
                                             src="@Model.LogoUrl"
                                             alt="Logo"
                                             style="max-height:60px; max-width:200px; border:1px solid #dee2e6; border-radius:6px; padding:4px; background:#fff;">
                                    </div>

                                    <input type="file" name="logoFile" id="logoFile"
                                           class="form-control"
                                           accept=".jpg,.jpeg,.png,.gif,.webp,.svg"
                                           onchange="previewLogo(this)">
                                    <div class="form-text">
                                        Chọn file ảnh (JPG, PNG, SVG...). Để trống nếu không muốn thay đổi.
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input asp-for="IsActive" class="form-check-input"
                                               type="checkbox" role="switch">
                                        <label asp-for="IsActive" class="form-check-label">
                                            Đang crawl
                                        </label>
                                    </div>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-save me-1"></i>Lưu thay đổi
                                    </button>
                                    <a asp-area="Admin" asp-controller="Source"
                                       asp-action="Index" class="btn btn-secondary">
                                        <i class="bi bi-arrow-left me-1"></i>Quay lại
                                    </a>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
<script>
function previewLogo(input) {
    const wrap = document.getElementById('logoPreviewWrap');
    const img  = document.getElementById('logoPreview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { img.src = e.target.result; wrap.style.display = ''; };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}