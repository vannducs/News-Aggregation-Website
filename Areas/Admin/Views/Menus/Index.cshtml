@model IEnumerable<Menu>
@{
    ViewData["Title"] = "Quản lý danh mục";
    var topMenus = Model.Where(m => m.ParentID == 0).OrderBy(m => m.Position).ThenBy(m => m.MenuOrder).ToList();
}

<main class="app-main">
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-6">
                    <h3 class="mb-0">Quản lý danh mục</h3>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-end">
                        <li class="breadcrumb-item">
                            <a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a>
                        </li>
                        <li class="breadcrumb-item active">Danh mục</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
    <div class="app-content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0">Danh sách danh mục điều hướng</h3>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Thêm danh mục
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Tên danh mục</th>
                                    <th>Loại</th>
                                    <th>Đường dẫn</th>
                                    <th>Vị trí</th>
                                    <th>Thứ tự</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var menu in topMenus)
                            {
                                var children = Model.Where(m => m.ParentID == menu.MenuID).OrderBy(m => m.MenuOrder).ToList();
                                <tr class="table-light">
                                    <td class="fw-semibold">@menu.MenuName</td>
                                    <td>Danh mục cha</td>
                                    <td>@(menu.Link ?? $"/{menu.ControllerName}/{menu.ActionName}")</td>
                                    <td>@(menu.Position == 1 ? "Điều hướng chính" : "Phụ / Footer")</td>
                                    <td>@menu.MenuOrder</td>
                                    <td>
                                        <span class="badge @(menu.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                            @(menu.IsActive ? "Đang hiện" : "Đã ẩn")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <form asp-action="MoveUp" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@menu.MenuID" />
                                                <button type="submit" class="btn btn-sm btn-outline-dark" title="Lên">↑</button>
                                            </form>
                                            <form asp-action="MoveDown" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@menu.MenuID" />
                                                <button type="submit" class="btn btn-sm btn-outline-dark" title="Xuống">↓</button>
                                            </form>
                                            <a asp-action="Edit" asp-route-id="@menu.MenuID"
                                               class="btn btn-sm btn-outline-primary">Sửa</a>
                                            <form asp-action="ToggleStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@menu.MenuID" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                                    @(menu.IsActive ? "Ẩn" : "Hiện")
                                                </button>
                                            </form>
                                            <form asp-action="Delete" method="post"
                                                  onsubmit="return confirm('Xóa danh mục này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@menu.MenuID" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>

                                @foreach (var child in children)
                                {
                                    <tr>
                                        <td class="ps-4">↳ @child.MenuName</td>
                                        <td>Danh mục con</td>
                                        <td>@(child.Link ?? $"/{child.ControllerName}/{child.ActionName}")</td>
                                        <td>@(child.Position == 1 ? "Điều hướng chính" : "Phụ / Footer")</td>
                                        <td>@child.MenuOrder</td>
                                        <td>
                                            <span class="badge @(child.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                                @(child.IsActive ? "Đang hiện" : "Đã ẩn")
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group">
                                                <form asp-action="MoveUp" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@child.MenuID" />
                                                    <button type="submit" class="btn btn-sm btn-outline-dark" title="Lên">↑</button>
                                                </form>
                                                <form asp-action="MoveDown" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@child.MenuID" />
                                                    <button type="submit" class="btn btn-sm btn-outline-dark" title="Xuống">↓</button>
                                                </form>
                                                <a asp-action="Edit" asp-route-id="@child.MenuID"
                                                   class="btn btn-sm btn-outline-primary">Sửa</a>
                                                <form asp-action="ToggleStatus" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@child.MenuID" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                                        @(child.IsActive ? "Ẩn" : "Hiện")
                                                    </button>
                                                </form>
                                                <form asp-action="Delete" method="post"
                                                      onsubmit="return confirm('Xóa danh mục này?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@child.MenuID" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
