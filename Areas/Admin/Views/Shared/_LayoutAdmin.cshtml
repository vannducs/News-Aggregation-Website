<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - News Aggregator Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fontsource/source-sans-3@5.0.12/index.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/admin/dist/css/adminlte.css" />
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                    <li class="nav-item d-none d-md-block">
                        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="nav-link">Dashboard</a>
                    </li>
                    <li class="nav-item d-none d-md-block">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link">Trang tin</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <span class="nav-link text-secondary">
                            @(User.FindFirst("FullName")?.Value ?? User.Identity?.Name) - @(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link btn btn-link">Dang xuat</button>
                        </form>
                    </li>
                </ul>
            </div>
        </nav>

        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
            <div class="sidebar-brand">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="brand-link">
                    <img src="~/admin/dist/assets/img/AdminLTELogo.png" alt="Admin" class="brand-image opacity-75 shadow" />
                    <span class="brand-text fw-light">News Admin</span>
                </a>
            </div>

            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation" data-accordion="false">
                        <li class="nav-header">QUAN TRI NOI DUNG</li>
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                                <i class="nav-icon bi bi-speedometer2"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        @if (User.IsInRole(NewsAggregator.Models.UserRoles.Admin))
                        {
                            <li class="nav-item">
                                <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                                    <i class="nav-icon bi bi-people-fill"></i>
                                    <p>Quan ly nguoi dung</p>
                                </a>
                            </li>
                        }
                        @if (User.IsInRole(NewsAggregator.Models.UserRoles.Admin) || User.IsInRole(NewsAggregator.Models.UserRoles.Editor))
                        {
                            <li class="nav-item">
                                <a asp-area="Admin" asp-controller="Menus" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Menus" ? "active" : "")">
                                    <i class="nav-icon bi bi-menu-button-wide-fill"></i>
                                    <p>Quan ly menu</p>
                                </a>
                            </li>
                        }
                        @if (User.IsInRole(NewsAggregator.Models.UserRoles.Admin) || User.IsInRole(NewsAggregator.Models.UserRoles.Moderator))
                        {
                            <li class="nav-item">
                                <a asp-area="Admin" asp-controller="Comments" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Comments" ? "active" : "")">
                                    <i class="nav-icon bi bi-chat-dots-fill"></i>
                                    <p>Quan ly binh luan</p>
                                </a>
                            </li>
                        }
                        <li class="nav-header">THAO TAC NHANH</li>
                        @if (User.IsInRole(NewsAggregator.Models.UserRoles.Admin))
                        {
                            <li class="nav-item">
                                <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="nav-link">
                                    <i class="nav-icon bi bi-person-plus-fill"></i>
                                    <p>Them thanh vien</p>
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link">
                                <i class="nav-icon bi bi-box-arrow-up-right"></i>
                                <p>Xem trang nguoi dung</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="" asp-controller="Account" asp-action="Profile" class="nav-link">
                                <i class="nav-icon bi bi-person-circle"></i>
                                <p>Ho so ca nhan</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        @RenderBody()

        <footer class="app-footer">
            <strong>
                News Aggregator Admin
            </strong>
            <div class="float-end d-none d-sm-inline">
                Quan ly tin tuc, nguon tin va nguoi dung
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js"></script>
    <script src="~/admin/dist/js/adminlte.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
