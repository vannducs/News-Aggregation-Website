@model AdminUserFormViewModel
@{
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Cap nhat nguoi dung" : "Them nguoi dung";
}

<main class="app-main">
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-6">
                    <h3 class="mb-0">@(isEdit ? "Cap nhat nguoi dung" : "Them nguoi dung")</h3>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-end">
                        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index">Nguoi dung</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@(isEdit ? "Chinh sua" : "Tao moi")</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="app-content">
        <div class="container-fluid">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title mb-0">Thong tin tai khoan</h3>
                </div>
                <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.AppUserID" method="post">
                    <div class="card-body">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input asp-for="AppUserID" type="hidden" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="UserName" class="form-label"></label>
                                <input asp-for="UserName" class="form-control" />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Role" class="form-label"></label>
                                <select asp-for="Role" class="form-select">
                                    @foreach (var role in AdminUserFormViewModel.AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <span asp-validation-for="Role" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label">So dien thoai</label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label">Ngay sinh</label>
                                <input asp-for="DateOfBirth" class="form-control" />
                                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Address" class="form-label">Dia chi</label>
                                <input asp-for="Address" class="form-control" />
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="AvatarUrl" class="form-label">Avatar URL</label>
                                <input asp-for="AvatarUrl" class="form-control" />
                                <span asp-validation-for="AvatarUrl" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Bio" class="form-label">Gioi thieu</label>
                                <textarea asp-for="Bio" rows="4" class="form-control"></textarea>
                                <span asp-validation-for="Bio" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label">
                                    @(isEdit ? "Mat khau moi (de trong neu giu nguyen)" : "Mat khau")
                                </label>
                                <input asp-for="Password" class="form-control" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" class="form-check-input" />
                                    <label asp-for="IsActive" class="form-check-label">Tai khoan dang hoat dong</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai</a>
                        <button type="submit" class="btn btn-primary">@(isEdit ? "Luu thay doi" : "Tao nguoi dung")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
